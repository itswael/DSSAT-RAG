# Database configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dssat_rag
POSTGRES_SCHEMA=public

# Qdrant configuration (optional)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# OpenAI settings (required for chat)
# Set these so planner and response generator use the same credentials
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=

# Application settings
APP_NAME="DSSAT RAG Backend"
APP_VERSION="1.0.0"
DEBUG=False
